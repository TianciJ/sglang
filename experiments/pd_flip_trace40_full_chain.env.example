# Copy to /home/tiancij/trace40-full-chain.env on the coordinator and chmod 600.
ADMIN_API_KEY=replace-with-the-existing-private-admin-key
IMAGE=sglang-pd-switch:tianciJ
SGLANG_REPO=/home/tiancij/sglang-pd-deepseek-dp8
TRACE_PATH=/home/tiancij/pd-artifacts/20260713-095054-trace40/trace/trace_interleaved_long_decode.jsonl
ARTIFACT_ROOT=/home/tiancij/pd-artifacts
TRACE_WAVE_SIZE=10
TRACE_WAVE_GAP_SECONDS=6
TRACE_INTRA_WAVE_INTERVAL_SECONDS=0.15
TRACE_TTFT_SLO_OVERRIDE_SECONDS=0
TRACE_TPOT_SLO_OVERRIDE_SECONDS=0.05
TRACE_MAX_TOKENS=10000
TRACE_FORCED_TEXT=字
MODEL_PATH=/models/deepseek_v3.1_terminus
MODEL_ID=deepseek_v3.1_terminus
TP_SIZE=8
DP_SIZE=8
ENABLE_CUSTOM_LOGIT_PROCESSOR=1
WORKLOAD_TIMEOUT_SECONDS=7200
MEASUREMENT_DURATION_SECONDS=7200

PD_FLIP_FIRST_MIGRATION_RATIO=0.5
PD_FLIP_OBSERVATION_SECONDS=10
PD_FLIP_SLO_THRESHOLD=0.99
PD_FLIP_MIN_PREFILL_SLO_SAMPLES=10
PD_FLIP_MIN_DECODE_SLO_SAMPLES=10
PD_FLIP_MONITOR_ITERATIONS=120
PD_FLIP_MONITOR_POLL_INTERVAL=0.25

# Required by this runner: workers expose the Prefill donor endpoints and the
# controller enforces donor-only prompt provenance.
ENABLE_PD_FLIP_PREFILL_DONOR=1
PD_FLIP_PREFILL_DONOR_MODE=1
