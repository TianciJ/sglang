# Copy to an untracked private file and export ENV_FILE=/absolute/path/to/file.
ADMIN_API_KEY=replace-with-a-private-secret
# Preferred on the controller: point to a chmod-600 file containing either
# the raw key or ADMIN_API_KEY=<key>. When set, it overrides the line above.
ADMIN_API_KEY_FILE=

IMAGE=tiancij/sglang-upstream:v0.5.15-clean
HELPER_IMAGE=tiancij/sglang-upstream:v0.5.15-clean
MODEL_PATH=/models/Qwen3-Next-80B-A3B-Instruct
MODEL_ID=Qwen3-Next-80B-A3B-Instruct
TOKENIZER_PATH=/models/Qwen3-Next-80B-A3B-Instruct/tokenizer.json

NODE0_HOST=cloud-099
NODE1_HOST=cloud-100
NODE2_HOST=cloud-101
NODE3_HOST=cloud-102
NODE0_IP=192.168.0.42
NODE1_IP=192.168.0.40
NODE2_IP=192.168.0.39
NODE3_IP=192.168.0.41
NODE0_MOONCAKE_HOST=fd03:4514:80:6241::1
NODE1_MOONCAKE_HOST=fd03:4514:80:7b81::1
NODE2_MOONCAKE_HOST=fd03:4514:80:6601::1
NODE3_MOONCAKE_HOST=fd03:4514:80:5f01::1
NODE0_ROLE=prefill
NODE1_ROLE=decode
NODE2_ROLE=decode
NODE3_ROLE=decode

GPU_IDS=0,1
TP_SIZE=2
DP_SIZE=1
WORKER_PORT=30000
ROUTER_PORT=8000
BOOTSTRAP_PORT=8998
MEM_FRACTION_STATIC=0.80
IB_DEVICE=mlx5_bond_1
MC_USE_IPV6=1
MC_GID_INDEX=3
MOONCAKE_PROTOCOL=rdma

# These paths exist on the controller node (cloud-099). The helper repository
# is mounted only into a non-GPU client/report container, never into a worker or router.
REMOTE_HELPER_REPO=/root/sglang
REMOTE_ARTIFACT_ROOT=/root/tiancij-upstream-baseline-runs
ROUTER_ARTIFACT_DIR=/root/tiancij-upstream-router-artifacts/v0.5.15-clean

WORKER_HEALTH_ATTEMPTS=1800
ROUTER_HEALTH_ATTEMPTS=300
HEALTH_POLL_SECONDS=2
WORKLOAD_TIMEOUT_SECONDS=7200
TRACE_INTERVAL_SECONDS=0.2
TRACE_LONG_TTFT_SLO_SECONDS=0.45
TRACE_SHORT_TTFT_SLO_SECONDS=0.25
