# Copy to a private file on the coordinator and set ADMIN_API_KEY there.
ADMIN_API_KEY=replace-with-the-existing-private-admin-key
IMAGE=sglang-pd-switch:tianciJ
SGLANG_REPO=/home/tiancij/sglang-pd-qwen80b
MODEL_PATH=/models/Qwen3-Next-80B-A3B-Instruct
MODEL_ID=Qwen3-Next-80B-A3B-Instruct
ARTIFACT_ROOT=/home/tiancij/pd-artifacts

NODE0_SSH=cloud-099
NODE1_SSH=cloud-100
NODE2_SSH=cloud-101
NODE3_SSH=cloud-102
NODE0_IP=192.168.0.42
NODE1_IP=192.168.0.40
NODE2_IP=192.168.0.39
NODE3_IP=192.168.0.41

PORT=30000
ROUTER_PORT=8000
BOOTSTRAP_PORT=8998
TRANSFER_BACKEND=mooncake
IB_DEVICE=mlx5_0
MEM_FRACTION_STATIC=0.88
GPU_IDS=0,1,2,3
TP_SIZE=4
DP_SIZE=1
ENABLE_DP_ATTENTION=0
ENABLE_CUSTOM_LOGIT_PROCESSOR=1
ENABLE_REQUEST_TIME_STATS_LOGGING=1
EXTRA_SGLANG_ARGS="--trust-remote-code --mamba-scheduler-strategy extra_buffer --enable-metrics"

TRACE_REQUESTS=40
TRACE_MAX_TOKENS=10000
TRACE_FORCED_TEXT=的
TRACE_INTRA_WAVE_INTERVAL_SECONDS=0.5
TRACE_WAVE_START_INTERVAL_SECONDS=7.5
WORKLOAD_TIMEOUT_SECONDS=7200
MEASUREMENT_DURATION_SECONDS=7200

PD_FLIP_FIRST_MIGRATION_RATIO=0.5
PD_FLIP_OBSERVATION_SECONDS=3
SLO_WINDOW_SECONDS=10
SLO_ENTER_THRESHOLD=0.90
SLO_RECOVER_THRESHOLD=0.95
MIN_TTFT_SAMPLES=10
MIN_TPOT_INTERVALS=100
CONTROLLER_POLL_SECONDS=0.25
PD_FLIP_MONITOR_ITERATIONS=2400

# The harness never copies or downloads this model. Preflight lists every node
# where config.json or model weight shards are missing.
