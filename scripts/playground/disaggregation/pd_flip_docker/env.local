SGLANG_REPO=/home/tiancij/sglang-pd-deepseek-dp8
IMAGE=sglang-pd-switch:tianciJ

MODEL_PATH=/models/deepseek_v3.1_terminus
MODEL_ID=deepseek_v3.1_terminus
TOKENIZER_PATH=/models/deepseek_v3.1_terminus

TP_SIZE=8
DP_SIZE=8
PORT=30000
BOOTSTRAP_PORT=8998
MEM_FRACTION_STATIC=0.88

TRANSFER_BACKEND=mooncake
IB_DEVICE=mlx5_0
ENABLE_CUSTOM_LOGIT_PROCESSOR=1
ENABLE_PD_FLIP_PREFILL_DONOR=1
PD_FLIP_PREFILL_DONOR_MODE=1
MOONCAKE_MASTER=192.168.0.42:50051
MOONCAKE_TE_META_DATA_SERVER=http://192.168.0.42:8080/metadata
MOONCAKE_GLOBAL_SEGMENT_SIZE=0
MOONCAKE_PROTOCOL=rdma
MOONCAKE_DEVICE=mlx5_0

NODE0_HOST=cloud-099
NODE1_HOST=cloud-100
NODE2_HOST=cloud-101
NODE3_HOST=cloud-102
NODE0_ROLE=prefill
NODE1_ROLE=prefill
NODE2_ROLE=decode
NODE3_ROLE=decode

ROUTER_HOST=127.0.0.1
ROUTER_PORT=8000
NODE0=http://192.168.0.42:30000
NODE1=http://192.168.0.40:30000
NODE2=http://192.168.0.39:30000
NODE3=http://192.168.0.41:30000

TTFT_SLO_SECONDS=5
TPOT_SLO_SECONDS=0.02
PD_FLIP_WINDOW_SECONDS=30
PD_FLIP_ENTER_THRESHOLD=0.9
PD_FLIP_EXIT_THRESHOLD=0.95
PD_FLIP_COMMIT_THRESHOLD=0.9
PD_FLIP_MONITOR_ITERATIONS=90
PD_FLIP_MONITOR_POLL_INTERVAL=1

EXTRA_SGLANG_ARGS='--trust-remote-code --enable-metrics --served-model-name deepseek_v3.1_terminus --page-size 64'
EXTRA_DOCKER_ARGS=
EXTRA_ROUTER_ARGS=

ROUTER_CRATES_MIRROR_URL=sparse+https://rsproxy.cn/index/
ROUTER_DYNAMO_TARBALL_FALLBACK=1
